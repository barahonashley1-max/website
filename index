<script>
/* ─────────────────────────────────────────────────────────────────────────
   HERO LOGO ANIMATION
───────────────────────────────────────────────────────────────────────── */
(function initHeroAnimation() {
  var svg   = document.getElementById('hero-svg');
  var lines = ['hl1','hl2','hl3','hl4'];
  var knots = ['hk1','hk2','hk3','hk4','hk5'];
  var wm    = document.getElementById('hero-wm');
  var tag   = document.getElementById('hero-tag');

  var knotTimings = [380, 60, 740, 1100, 1460];

  lines.forEach(function(id, i) {
    setTimeout(function() {
      var el = document.getElementById(id);
      if (el) el.classList.add('drawn');
    }, 300 + i * 350);
  });

  knots.forEach(function(id, i) {
    setTimeout(function() {
      var el = document.getElementById(id);
      if (el) el.classList.add('visible');
    }, knotTimings[i] + 200);
  });

  setTimeout(function() { if (wm) wm.classList.add('show'); }, 1900);
  setTimeout(function() { if (tag) tag.classList.add('show'); }, 2200);

  setTimeout(function() {
    if (svg) svg.closest('.hero__logo-stage').classList.add('hero-done');
  }, 2800);
})();

/* ─────────────────────────────────────────────────────────────────────────
   SCROLL REVEAL — IntersectionObserver
───────────────────────────────────────────────────────────────────────── */
var revealObserver = new IntersectionObserver(function(entries) {
  entries.forEach(function(e) {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      revealObserver.unobserve(e.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.reveal').forEach(function(el) {
  revealObserver.observe(el);
});

/* ─────────────────────────────────────────────────────────────────────────
   NAV — scroll behavior + mobile
───────────────────────────────────────────────────────────────────────── */
var nav = document.getElementById('main-nav');

window.addEventListener('scroll', function() {
  nav.classList.toggle('nav--scrolled', window.scrollY > 40);
}, { passive: true });

var burger     = document.getElementById('nav-burger');
var mobileMenu = document.getElementById('mobile-menu');
var menuOpen   = false;

burger.addEventListener('click', function() {
  menuOpen = !menuOpen;
  burger.classList.toggle('open', menuOpen);
  mobileMenu.classList.toggle('open', menuOpen);
  burger.setAttribute('aria-expanded', menuOpen.toString());
  document.body.style.overflow = menuOpen ? 'hidden' : '';
});

function closeMobile() {
  menuOpen = false;
  burger.classList.remove('open');
  mobileMenu.classList.remove('open');
  burger.setAttribute('aria-expanded', 'false');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && menuOpen) closeMobile();
});

/* ─────────────────────────────────────────────────────────────────────────
   ACTIVE NAV LINK on scroll
───────────────────────────────────────────────────────────────────────── */
var navLinks = document.querySelectorAll('.nav__links a');
var sections = document.querySelectorAll('section[id]');

function updateActiveNav() {
  var scrollY = window.scrollY + 100;
  var current = '';
  sections.forEach(function(sec) {
    if (sec.offsetTop <= scrollY) current = sec.getAttribute('id');
  });
  navLinks.forEach(function(a) {
    var href = a.getAttribute('href').replace('#', '');
    a.classList.toggle('active', href === current);
  });
}

window.addEventListener('scroll', updateActiveNav, { passive: true });

/* ─────────────────────────────────────────────────────────────────────────
   MODAL SYSTEM — services + gallery
───────────────────────────────────────────────────────────────────────── */
function openModal(id) {
  var overlay = document.getElementById(id);
  if (!overlay) return;
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
  // Focus management
  var closeBtn = overlay.querySelector('.modal-box__close');
  if (closeBtn) setTimeout(function() { closeBtn.focus(); }, 50);
}

function closeModal(id) {
  var overlay = document.getElementById(id);
  if (!overlay) return;
  overlay.classList.remove('open');
  document.body.style.overflow = '';
}

function handleModalClick(event, id) {
  // Close when clicking the dark overlay area (not the modal box itself)
  if (event.target === document.getElementById(id)) {
    closeModal(id);
  }
}

// Close modals on Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.querySelectorAll('.modal-overlay.open').forEach(function(m) {
      m.classList.remove('open');
    });
    document.body.style.overflow = '';
  }
});

// Keyboard accessibility for insp-cards
document.querySelectorAll('.insp-card[tabindex]').forEach(function(card) {
  card.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      card.click();
    }
  });
});

/* ─────────────────────────────────────────────────────────────────────────
   NEWSLETTER FORM
───────────────────────────────────────────────────────────────────────── */
function handleNewsletter(e) {
  e.preventDefault();
  var form  = document.getElementById('newsletter-form');
  var input = form.querySelector('input');
  var btn   = form.querySelector('button');
  var email = input.value.trim();

  if (!email || !email.includes('@')) {
    input.style.borderColor = 'rgba(224,75,74,.6)';
    setTimeout(function() { input.style.borderColor = ''; }, 2000);
    return;
  }

  btn.textContent = '¡Suscrito!';
  btn.style.background = '#3A3830';
  input.value = '';
  input.placeholder = 'Gracias — te escribiremos pronto';

  setTimeout(function() {
    btn.textContent = 'Suscribirme';
    btn.style.background = '';
    input.placeholder = 'Tu correo corporativo';
  }, 4000);
}

/* ─────────────────────────────────────────────────────────────────────────
   CONTACT FORM — validation + success message
───────────────────────────────────────────────────────────────────────── */
function handleContactForm(e) {
  e.preventDefault();
  var form = document.getElementById('contact-form');
  var success = document.getElementById('contact-success');

  // Basic HTML5 validation
  if (!form.checkValidity()) {
    // Trigger native validation UI
    var firstInvalid = form.querySelector(':invalid');
    if (firstInvalid) {
      firstInvalid.focus();
      firstInvalid.style.borderColor = 'rgba(224,75,74,.6)';
      setTimeout(function() { firstInvalid.style.borderColor = ''; }, 2500);
    }
    return;
  }

  // Check radio selection
  var radioSelected = form.querySelector('input[name="interes"]:checked');
  if (!radioSelected) {
    var firstRadio = form.querySelector('input[name="interes"]');
    if (firstRadio) firstRadio.focus();
    return;
  }

  // Show success, hide form
  form.style.display = 'none';
  success.style.display = 'block';
  success.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

/* ─────────────────────────────────────────────────────────────────────────
   SMOOTH SCROLL — override hash links for offset compensation
───────────────────────────────────────────────────────────────────────── */
document.querySelectorAll('a[href^="#"]:not(.btn-diagnostico)').forEach(function(a) {
  a.addEventListener('click', function(e) {
    var href = a.getAttribute('href');
    if (href === '#') return;
    var target = document.querySelector(href);
    if (!target) return;
    e.preventDefault();
    // Close mobile menu if open
    if (menuOpen) closeMobile();
    var offset = nav.offsetHeight + 16;
    var top = target.getBoundingClientRect().top + window.scrollY - offset;
    window.scrollTo({ top: top, behavior: 'smooth' });
  });
});

/* ── TALLY: cargar todos los iframes embed ── */
(function() {
  var s = document.createElement('script');
  s.src = 'https://tally.so/widgets/embed.js';
  s.onload = function() { if (window.Tally) window.Tally.loadEmbeds(); };
  document.body.appendChild(s);
})();
</script>

