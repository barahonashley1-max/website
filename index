<style>
/* ═══════════════════════════════════════════════════════════════════════
   MÉTODO PACIOLI — metodopacioli.com
   CSS Architecture: Custom Properties → Reset → Layout → Components → Animations
   ═══════════════════════════════════════════════════════════════════════ */

/* ─── DESIGN TOKENS ─── */
:root {
  --black:       #0A0A0A;
  --ink:         #1A1A18;
  --white:       #FFFFFF;
  --parchment:   #F5F0E8;
  --warm:        #EDE8DC;
  --gold:        #B8A87A;
  --gold-d:      #8C7A52;
  --gold-l:      #D4C99A;
  --silver:      #8A8880;
  --pale:        #D4CFC4;
  --carbon:      #3A3830;

  --display:     'Cinzel', serif;
  --serif:       'Cormorant Garamond', Georgia, serif;
  --fell:        'IM Fell English', serif;

  --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);

  --nav-h: 64px;
  --max-w: 1160px;
  --radius: 0px; /* Deliberately sharp — editorial */
}

/* ─── RESET ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
/* Base font increased to 18px */
html { scroll-behavior: smooth; font-size: 18px; -webkit-text-size-adjust: 100%; }
body {
  background: var(--white);
  color: var(--ink);
  font-family: var(--serif);
  font-size: 1.0rem;
  line-height: 1.8;
  overflow-x: hidden;
}
img, svg { display: block; max-width: 100%; }
a { text-decoration: none; color: inherit; }
button, input, select, textarea { font-family: inherit; }
button { cursor: pointer; border: none; background: none; }
ul { list-style: none; }

/* ─── UTILITIES ─── */
.container { max-width: var(--max-w); margin: 0 auto; padding: 0 2.5rem; }
.container--narrow { max-width: 780px; margin: 0 auto; padding: 0 2.5rem; }

.label-text {
  font-family: var(--display);
  font-size: .6rem;
  letter-spacing: .42em;
  text-transform: uppercase;
  color: var(--gold-d);
  display: block;
}
.label-text--light { color: var(--gold); }
.label-text--center { text-align: center; }

.gold-rule {
  width: 48px; height: 1px;
  background: var(--gold);
  opacity: .65;
  margin: 1.25rem 0 2rem;
}
.gold-rule--center { margin-left: auto; margin-right: auto; }
.gold-rule--right { margin-left: auto; }

/* ─── SCROLL REVEAL ─── */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity .7s var(--ease-out), transform .7s var(--ease-out);
}
.reveal.visible { opacity: 1; transform: none; }
.reveal-d1 { transition-delay: .1s; }
.reveal-d2 { transition-delay: .2s; }
.reveal-d3 { transition-delay: .3s; }
.reveal-d4 { transition-delay: .4s; }
.reveal-d5 { transition-delay: .5s; }

/* ═══════════════════════════════════════════════════════════════════════
   NAVIGATION
   ═══════════════════════════════════════════════════════════════════════ */
.nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 1000;
  height: var(--nav-h);
  background: rgba(255,255,255,.97);
  border-bottom: 1px solid rgba(184,168,122,.14);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex; align-items: center;
  transition: box-shadow .3s;
}
.nav.nav--scrolled { box-shadow: 0 2px 32px rgba(0,0,0,.07); }
.nav__inner {
  max-width: var(--max-w); margin: 0 auto; padding: 0 2.5rem;
  width: 100%;
  display: flex; align-items: center; justify-content: space-between;
}
.nav__logo { display: flex; align-items: center; gap: .9rem; }
.nav__logo-mark { width: 34px; height: 30px; flex-shrink: 0; }
.nav__logo-text {
  font-family: var(--display);
  font-size: .72rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--ink);
  line-height: 1.2;
}
.nav__logo-text em {
  display: block;
  font-family: var(--fell);
  font-style: italic;
  font-size: .58rem;
  letter-spacing: .06em;
  color: var(--gold-d);
  text-transform: none;
}
.nav__links {
  display: flex; align-items: center; gap: 1.6rem;
}
.nav__links a {
  font-family: var(--display);
  font-size: .52rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--silver);
  transition: color .25s;
  position: relative;
  padding-bottom: 2px;
}
.nav__links a::after {
  content: '';
  position: absolute; bottom: -2px; left: 0; right: 0;
  height: 1px; background: var(--gold-d);
  transform: scaleX(0); transform-origin: left;
  transition: transform .3s var(--ease-out);
}
.nav__links a:hover,
.nav__links a.active { color: var(--ink); }
.nav__links a:hover::after,
.nav__links a.active::after { transform: scaleX(1); }
.nav__cta {
  font-family: var(--display);
  font-size: .52rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  padding: .55rem 1.2rem;
  background: var(--ink);
  color: var(--parchment);
  border: 1px solid var(--ink);
  transition: background .25s, color .25s, transform .2s;
}
.nav__cta:hover { background: var(--gold-d); border-color: var(--gold-d); transform: translateY(-1px); }
.nav__burger {
  display: none; flex-direction: column; gap: 5px;
  padding: 4px; width: 30px;
}
.nav__burger span {
  display: block; width: 100%; height: 1.5px;
  background: var(--ink); transition: .3s;
}
.nav__burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav__burger.open span:nth-child(2) { opacity: 0; }
.nav__burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

.mobile-menu {
  display: none; position: fixed;
  inset: 0; z-index: 999;
  background: var(--white);
  padding: calc(var(--nav-h) + 2rem) 2.5rem 3rem;
  flex-direction: column; gap: 0;
  overflow-y: auto;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  font-family: var(--display);
  font-size: 1rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--ink);
  padding: 1.1rem 0;
  border-bottom: 1px solid rgba(184,168,122,.12);
  transition: color .25s, padding-left .25s;
}
.mobile-menu a:hover { color: var(--gold-d); padding-left: .5rem; }
.mobile-menu__close { margin-top: 2rem; }

/* ═══════════════════════════════════════════════════════════════════════
   HERO — SPLIT LAYOUT
   ═══════════════════════════════════════════════════════════════════════ */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-top: var(--nav-h);
}

/* Left — White */
.hero__left {
  display: flex; flex-direction: column; justify-content: center;
  padding: 7rem 4rem 6rem 2.5rem;
  position: relative;
}
.hero__eyebrow {
  display: flex; align-items: center; gap: 1rem;
  margin-bottom: 2rem;
}
.hero__eyebrow::before {
  content: ''; display: block;
  width: 32px; height: 1px; background: var(--gold);
}
.hero__headline {
  font-family: var(--display);
  font-size: clamp(2.4rem, 4.5vw, 3.8rem);
  font-weight: 700;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: var(--ink);
  line-height: .94;
  margin-bottom: 1.6rem;
}
.hero__headline em {
  font-style: normal;
  color: var(--gold-d);
}
.hero__sub {
  font-family: var(--fell);
  font-style: italic;
  font-size: clamp(1rem, 1.6vw, 1.2rem);
  color: var(--silver);
  line-height: 1.72;
  max-width: 460px;
  margin-bottom: 2.8rem;
}
.hero__ctas {
  display: flex; gap: 1rem; flex-wrap: wrap;
  margin-bottom: 3.5rem;
}
.btn-primary {
  display: inline-flex; align-items: center; gap: .6rem;
  font-family: var(--display);
  font-size: .55rem; letter-spacing: .2em; text-transform: uppercase;
  padding: .95rem 2rem;
  background: var(--ink); color: var(--parchment);
  border: 1px solid var(--ink);
  transition: background .25s, border-color .25s, transform .2s;
}
.btn-primary:hover { background: var(--gold-d); border-color: var(--gold-d); transform: translateY(-2px); }
.btn-secondary {
  display: inline-flex; align-items: center; gap: .6rem;
  font-family: var(--display);
  font-size: .55rem; letter-spacing: .2em; text-transform: uppercase;
  padding: .95rem 2rem;
  background: transparent; color: var(--ink);
  border: 1px solid rgba(184,168,122,.45);
  transition: border-color .25s, color .25s, transform .2s;
}
.btn-secondary:hover { border-color: var(--gold-d); color: var(--gold-d); transform: translateY(-2px); }
.btn-arrow {
  width: 14px; height: 10px;
  stroke: currentColor; stroke-width: 1.3;
  fill: none;
}
.hero__stats {
  display: flex; gap: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(184,168,122,.2);
}
.hero__stat-num {
  font-family: var(--display);
  font-size: 1.8rem; font-weight: 600;
  letter-spacing: .03em; color: var(--ink);
  line-height: 1;
}
.hero__stat-label {
  font-family: var(--fell); font-style: italic;
  font-size: .83rem; color: var(--silver);
  margin-top: .25rem;
}

/* Right — Black */
.hero__right {
  background: var(--ink);
  position: relative; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.hero__grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(184,168,122,.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(184,168,122,.035) 1px, transparent 1px);
  background-size: 42px 42px;
}
.hero__corner {
  position: absolute; width: 20px; height: 20px;
  border-color: rgba(184,168,122,.3); border-style: solid;
}
.hero__corner--tl { top: 24px; left: 24px; border-width: 1px 0 0 1px; }
.hero__corner--tr { top: 24px; right: 24px; border-width: 1px 1px 0 0; }
.hero__corner--bl { bottom: 24px; left: 24px; border-width: 0 0 1px 1px; }
.hero__corner--br { bottom: 24px; right: 24px; border-width: 0 1px 1px 0; }
.hero__logo-stage {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center;
  padding: 2rem;
}
#hero-svg { width: clamp(200px, 22vw, 280px); height: auto; overflow: visible; }
.hl { stroke-dasharray: 0 400; transition: stroke-dasharray .95s var(--ease-out); }
.hl.drawn { stroke-dasharray: 400 0; }
.hk {
  opacity: 0; transform: scale(0);
  transform-origin: center; transform-box: fill-box;
  transition: opacity .4s ease, transform .45s var(--ease-bounce);
}
.hk.visible { opacity: 1; transform: scale(1); }
.hero__logo-wordmark {
  font-family: var(--display);
  font-size: .88rem; letter-spacing: .32em; text-transform: uppercase;
  color: var(--parchment); margin-top: 2rem; margin-bottom: .4rem;
  opacity: 0; transform: translateY(10px);
  transition: opacity .8s var(--ease-out) 2s, transform .8s var(--ease-out) 2s;
}
.hero__logo-wordmark.show { opacity: 1; transform: none; }
.hero__logo-tagline {
  font-family: var(--fell); font-style: italic;
  font-size: .82rem; color: var(--gold); letter-spacing: .06em;
  opacity: 0; transform: translateY(8px);
  transition: opacity .8s var(--ease-out) 2.3s, transform .8s var(--ease-out) 2.3s;
}
.hero__logo-tagline.show { opacity: 1; transform: none; }

/* ═══════════════════════════════════════════════════════════════════════
   DISRUPTION BAND
   ═══════════════════════════════════════════════════════════════════════ */
.disruption {
  background: var(--parchment);
  padding: 6rem 0;
  position: relative; overflow: hidden;
}
.disruption__inner {
  max-width: var(--max-w); margin: 0 auto; padding: 0 2.5rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;
}
.disruption__mantra {
  font-family: var(--fell); font-style: italic;
  font-size: clamp(1.35rem, 2.2vw, 1.9rem);
  color: var(--ink); line-height: 1.5;
  margin-bottom: .5rem; display: block;
}
.disruption__mantra span {
  font-style: normal; font-family: var(--display);
  font-size: .72em; letter-spacing: .05em; font-weight: 600;
  color: var(--gold-d);
}
.disruption__note {
  margin-top: 2rem; font-family: var(--serif);
  font-size: .95rem; color: var(--silver); line-height: 1.85;
}
.disruption__note em { font-style: italic; color: var(--gold-d); }
.disruption__card {
  background: var(--ink); padding: 2.5rem;
  position: relative;
}
.disruption__card::before {
  content: ''; position: absolute; inset: -6px;
  border: 1px solid rgba(184,168,122,.16); pointer-events: none;
}
.disruption__card-label {
  font-family: var(--display); font-size: .58rem;
  letter-spacing: .36em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 1.8rem; display: block;
}
.disruption__steps { display: flex; flex-direction: column; gap: 1rem; }
.disruption__step { display: flex; align-items: flex-start; gap: 1.2rem; }
.disruption__step-num {
  font-family: var(--display); font-size: .5rem;
  letter-spacing: .22em; color: var(--gold); opacity: .6;
  min-width: 24px; padding-top: .15rem;
}
.disruption__step-title {
  font-family: var(--display); font-size: .78rem;
  letter-spacing: .1em; text-transform: uppercase; color: var(--parchment);
  display: block; margin-bottom: .25rem;
}
.disruption__step-desc {
  font-family: var(--serif); font-size: .88rem;
  color: rgba(245,240,232,.52); line-height: 1.7;
}

/* ═══════════════════════════════════════════════════════════════════════
   ECOSYSTEM
   ═══════════════════════════════════════════════════════════════════════ */
.ecosystem {
  padding: 7rem 0; background: var(--white);
}
.ecosystem__header {
  text-align: center; margin-bottom: 4rem;
}
.section-title {
  font-family: var(--display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 600; letter-spacing: .07em; text-transform: uppercase;
  color: var(--ink); line-height: 1.1;
}
.section-title--light { color: var(--white); }
.ecosystem__grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
}
.eco-card {
  padding: 3rem 2.5rem; position: relative; overflow: hidden;
  border: 1px solid rgba(184,168,122,.1);
  transition: background .3s;
  cursor: default;
}
.eco-card::after {
  content: ''; position: absolute;
  bottom: 0; left: 0; right: 0; height: 2px;
  background: var(--gold);
  transform: scaleX(0); transform-origin: left;
  transition: transform .4s var(--ease-out);
}
.eco-card:hover { background: var(--parchment); }
.eco-card:hover::after { transform: scaleX(1); }
.eco-card--dark { background: var(--ink); border-color: transparent; }
.eco-card--dark:hover { background: var(--carbon); }
.eco-card--soon { opacity: .6; pointer-events: none; }
.eco-card__num {
  font-family: var(--display); font-size: .5rem;
  letter-spacing: .3em; color: var(--gold-d); opacity: .5; margin-bottom: 1.5rem;
}
.eco-card--dark .eco-card__num { color: var(--gold); opacity: .5; }
.eco-card__icon { width: 44px; height: 44px; margin-bottom: 1.5rem; }
.eco-card__title {
  font-family: var(--display); font-size: .82rem;
  letter-spacing: .1em; text-transform: uppercase; color: var(--ink);
  margin-bottom: .9rem;
}
.eco-card--dark .eco-card__title { color: var(--parchment); }
.eco-card__desc {
  font-family: var(--serif); font-size: .9rem;
  color: var(--silver); line-height: 1.8; margin-bottom: 1.5rem;
}
.eco-card--dark .eco-card__desc { color: rgba(245,240,232,.52); }
.eco-card__tags { display: flex; flex-wrap: wrap; gap: .4rem; }
.eco-tag {
  font-family: var(--display); font-size: .46rem;
  letter-spacing: .14em; text-transform: uppercase;
  padding: .28rem .7rem;
  border: 1px solid rgba(184,168,122,.3); color: var(--gold-d);
}
.eco-card--dark .eco-tag { border-color: rgba(184,168,122,.22); color: var(--gold); }
.eco-tag--coming {
  background: rgba(184,168,122,.1); color: var(--gold-d);
  border-color: transparent; font-style: normal;
}
.eco-card__btn {
  display: inline-flex; align-items: center; gap: .5rem;
  font-family: var(--display); font-size: .48rem;
  letter-spacing: .18em; text-transform: uppercase;
  padding: .6rem 1.2rem; margin-top: 1.4rem;
  background: transparent; color: var(--gold-d);
  border: 1px solid rgba(184,168,122,.35);
  cursor: pointer;
  transition: background .25s, color .25s, border-color .25s, transform .2s;
}
.eco-card--dark .eco-card__btn { color: var(--gold); border-color: rgba(184,168,122,.3); }
.eco-card__btn:hover { background: var(--gold-d); color: var(--white); border-color: var(--gold-d); transform: translateY(-1px); }
.eco-card--dark .eco-card__btn:hover { background: var(--gold); border-color: var(--gold); color: var(--ink); }

/* ═══════════════════════════════════════════════════════════════════════
   SERVICES — with hover + modal
   ═══════════════════════════════════════════════════════════════════════ */
.services {
  padding: 7rem 0; background: var(--ink);
}
.services__header {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4rem; align-items: end; margin-bottom: 4rem;
}
.services__header-desc {
  font-family: var(--serif); font-size: .95rem;
  color: rgba(245,240,232,.55); line-height: 1.85;
}
.services__subtitle {
  font-family: var(--display); font-size: .62rem;
  letter-spacing: .28em; text-transform: uppercase;
  color: var(--gold); margin-top: 1.5rem;
  display: block;
}
.services__grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
}
.svc-card {
  background: var(--carbon); padding: 2.5rem 2rem 3.5rem;
  border-bottom: 2px solid transparent;
  position: relative; overflow: hidden;
  transition: border-color .3s, transform .3s, box-shadow .3s;
}
.svc-card:hover {
  border-color: var(--gold);
  transform: translateY(-5px);
  box-shadow: 0 16px 48px rgba(0,0,0,.28);
}
.svc-card__num {
  font-family: var(--display); font-size: .5rem;
  letter-spacing: .26em; color: var(--gold); opacity: .6; margin-bottom: .8rem;
}
.svc-card__icon { width: 40px; height: 40px; margin-bottom: 1.2rem; }
.svc-card__title {
  font-family: var(--display); font-size: .76rem;
  letter-spacing: .1em; text-transform: uppercase; color: var(--parchment);
  margin-bottom: .5rem;
}
.svc-card__subtitle {
  font-family: var(--fell); font-style: italic;
  font-size: .92rem; color: var(--gold); margin-bottom: 1.2rem;
}
.svc-card__items { }
.svc-card__item {
  font-family: var(--serif); font-size: .82rem; color: rgba(245,240,232,.5);
  padding: .28rem 0; border-bottom: 1px solid rgba(184,168,122,.1);
  display: flex; align-items: flex-start; gap: .6rem; line-height: 1.5;
}
.svc-card__item::before {
  content: '';
  display: block; width: 4px; height: 4px; border-radius: 50%;
  background: var(--gold); flex-shrink: 0; margin-top: .5rem;
}
.svc-card__item:last-child { border-bottom: none; }
/* Hover reveal button */
.svc-card__more-btn {
  position: absolute; bottom: 1.5rem; right: 1.5rem;
  font-family: var(--display); font-size: .46rem;
  letter-spacing: .16em; text-transform: uppercase;
  padding: .5rem 1rem;
  background: var(--gold-d); color: var(--white);
  border: none; cursor: pointer;
  opacity: 0; transform: translateY(6px);
  transition: opacity .25s var(--ease-out), transform .25s var(--ease-out), background .2s;
}
.svc-card:hover .svc-card__more-btn {
  opacity: 1; transform: translateY(0);
}
.svc-card__more-btn:hover { background: var(--gold); }

/* ═══════════════════════════════════════════════════════════════════════
   MODALS — services & gallery
   ═══════════════════════════════════════════════════════════════════════ */
.modal-overlay {
  position: fixed; inset: 0; z-index: 2000;
  background: rgba(26,26,24,.82);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  display: flex; align-items: center; justify-content: center;
  padding: 2rem;
  opacity: 0; pointer-events: none;
  transition: opacity .35s var(--ease-out);
}
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal-box {
  background: var(--white);
  max-width: 680px; width: 100%;
  max-height: 85vh; overflow-y: auto;
  position: relative;
  transform: translateY(20px) scale(.98);
  transition: transform .35s var(--ease-out);
}
.modal-overlay.open .modal-box { transform: translateY(0) scale(1); }
.modal-box__header {
  background: var(--ink); padding: 2.5rem 3rem 2rem;
  position: sticky; top: 0; z-index: 1;
}
.modal-box__close {
  position: absolute; top: 1.2rem; right: 1.5rem;
  font-family: var(--display); font-size: 1rem;
  color: var(--gold); cursor: pointer; background: none; border: none;
  line-height: 1; transition: color .2s, transform .2s;
}
.modal-box__close:hover { color: var(--parchment); transform: rotate(90deg); }
.modal-box__label {
  font-family: var(--display); font-size: .52rem;
  letter-spacing: .32em; text-transform: uppercase;
  color: var(--gold); margin-bottom: .75rem; display: block;
}
.modal-box__title {
  font-family: var(--display); font-size: 1.1rem;
  letter-spacing: .08em; text-transform: uppercase;
  color: var(--parchment); line-height: 1.2;
}
.modal-box__subtitle {
  font-family: var(--fell); font-style: italic;
  font-size: .9rem; color: var(--gold); margin-top: .3rem;
}
.modal-box__body { padding: 2.5rem 3rem; }
.modal-box__desc {
  font-family: var(--serif); font-size: .95rem;
  color: var(--silver); line-height: 1.9; margin-bottom: 2rem;
}
.modal-box__services-label {
  font-family: var(--display); font-size: .54rem;
  letter-spacing: .26em; text-transform: uppercase;
  color: var(--gold-d); margin-bottom: 1.2rem; display: block;
}
.modal-service-item {
  padding: 1.1rem 0; border-bottom: 1px solid rgba(184,168,122,.12);
}
.modal-service-item:last-child { border-bottom: none; }
.modal-service-item h4 {
  font-family: var(--display); font-size: .7rem;
  letter-spacing: .1em; text-transform: uppercase; color: var(--ink);
  margin-bottom: .4rem;
}
.modal-service-item p {
  font-family: var(--serif); font-size: .88rem;
  color: var(--silver); line-height: 1.75;
}

/* Gallery modal */
.modal-gallery { max-width: 820px; }
.modal-gallery__grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem;
  margin-top: 1.5rem;
}
.modal-gallery__img-wrap {
  position: relative; overflow: hidden;
  border: 1px solid rgba(184,168,122,.15);
  background: var(--warm);
}
.modal-gallery__img {
  width: 100%; aspect-ratio: 4/3;
  object-fit: cover; display: block;
  transition: transform .4s ease;
}
.modal-gallery__img-wrap:hover .modal-gallery__img {
  transform: scale(1.04);
}
.modal-gallery__caption {
  font-family: var(--display); font-size: .42rem;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--silver); opacity: .75;
  text-align: center; padding: .5rem .5rem .55rem;
  background: var(--parchment);
  border-top: 1px solid rgba(184,168,122,.12);
  margin: 0; line-height: 1.4;
}
/* placeholder style kept for any future empty slots */
.modal-gallery__placeholder {
  width: 100%; aspect-ratio: 4/3;
  background: var(--warm);
  border: 1px solid rgba(184,168,122,.2);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: .5rem;
}
.modal-gallery__placeholder span {
  font-family: var(--display); font-size: .44rem;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--gold-d); opacity: .5;
  text-align: center; padding: 0 .5rem;
}

/* ═══════════════════════════════════════════════════════════════════════
   PROCESS
   ═══════════════════════════════════════════════════════════════════════ */
.process {
  padding: 7rem 0; background: var(--warm);
}
.process__header { text-align: center; margin-bottom: 4.5rem; }
.process__steps {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 2px; position: relative;
}
.process__connector {
  position: absolute; top: 40px;
  left: 12.5%; right: 12.5%; height: 1px;
  background: linear-gradient(to right, transparent, rgba(140,122,82,.3) 20%, rgba(140,122,82,.3) 80%, transparent);
}
.process__step {
  padding: 3rem 1.5rem 2.5rem;
  text-align: center; position: relative;
}
.process__step-circle {
  width: 52px; height: 52px;
  border: 1px solid rgba(140,122,82,.5); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 1.5rem; background: var(--parchment);
  font-family: var(--display); font-size: .58rem;
  letter-spacing: .15em; color: var(--gold-d);
  position: relative; z-index: 1;
  transition: background .3s, border-color .3s;
}
.process__step:hover .process__step-circle {
  background: var(--gold-d); border-color: var(--gold-d); color: var(--white);
}
.process__step-title {
  font-family: var(--display); font-size: .72rem;
  letter-spacing: .12em; text-transform: uppercase; color: var(--ink);
  margin-bottom: .8rem;
}
.process__step-desc {
  font-family: var(--serif); font-size: .86rem;
  color: var(--silver); line-height: 1.75;
}

/* ═══════════════════════════════════════════════════════════════════════
   ABOUT — Quiénes Somos
   ═══════════════════════════════════════════════════════════════════════ */
.about {
  padding: 7rem 0; background: var(--white);
}
.about__inner {
  display: grid; grid-template-columns: 7fr 5fr;
  gap: 5rem; align-items: start;
}
/* Text column stays first in DOM (good for a11y/SEO) but renders left */
.about__text  { order: 1; }
/* Visual column renders on the right */
.about__visual { order: 2; position: relative; }
.about__frame {
  border: 1px solid rgba(184,168,122,.2);
  position: relative;
  background: var(--parchment);
}
.about__frame::before {
  content: ''; position: absolute; inset: -7px;
  border: 1px solid rgba(184,168,122,.08); pointer-events: none;
}
.about__caption {
  margin-top: 1rem; text-align: center;
  font-family: var(--display); font-size: .5rem;
  letter-spacing: .22em; text-transform: uppercase;
  color: var(--silver); opacity: .6;
}
.about__name {
  font-family: var(--display);
  font-size: clamp(1.1rem, 2vw, 1.6rem);
  letter-spacing: .06em; text-transform: uppercase; color: var(--ink);
  margin-bottom: .5rem; line-height: 1.25;
}
.about__bio {
  font-family: var(--serif); font-size: .95rem;
  color: var(--silver); line-height: 1.9; margin-bottom: 1.4rem;
}
.about__pillar {
  padding: 1.4rem 0; border-bottom: 1px solid rgba(184,168,122,.12);
}
.about__pillar:last-of-type { border-bottom: none; margin-bottom: 2rem; }

/* Illustrated variant — icon + content side by side */
.about__pillar--illustrated {
  display: grid;
  grid-template-columns: 64px 1fr;
  gap: 1.2rem;
  align-items: start;
  padding: 1.5rem 0;
}
.about__pillar-icon {
  width: 56px; height: 56px; flex-shrink: 0;
  padding: .5rem;
  border: 1px solid rgba(184,168,122,.15);
  background: var(--parchment);
  display: flex; align-items: center; justify-content: center;
}
.about__pillar-icon svg { width: 100%; height: 100%; }
.about__pillar-content { }
.about__pillar-title {
  font-family: var(--display); font-size: .7rem;
  letter-spacing: .14em; text-transform: uppercase; color: var(--ink);
  margin-bottom: .5rem; display: flex; align-items: center; gap: .6rem;
}
.about__pillar-title::before {
  content: ''; display: block; width: 6px; height: 6px;
  background: var(--gold); flex-shrink: 0;
}
.about__pillar-text {
  font-family: var(--serif); font-size: .9rem;
  color: var(--silver); line-height: 1.8;
}
.about__pillar-text em { font-style: italic; color: var(--gold-d); }
.about__credentials {
  display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 2.5rem;
}
.cred-tag {
  font-family: var(--display); font-size: .48rem;
  letter-spacing: .14em; text-transform: uppercase;
  padding: .36rem .9rem;
  border: 1px solid rgba(184,168,122,.3); color: var(--gold-d);
}
.about__btns { display: flex; gap: 1rem; flex-wrap: wrap; }

/* ═══════════════════════════════════════════════════════════════════════
   INSPIRATION
   ═══════════════════════════════════════════════════════════════════════ */
.inspiration {
  padding: 7rem 0; background: #D4C99A;
}
.inspiration__header { text-align: center; margin-bottom: 4.5rem; }
.inspiration__grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
}
.insp-card {
  padding: 3rem 2rem; text-align: center;
  border: 1px solid rgba(140,122,82,.2);
  background: rgba(255,255,255,.25);
  transition: background .3s, transform .3s;
  cursor: pointer;
}
.insp-card:hover { background: rgba(255,255,255,.65); transform: translateY(-3px); }
.insp-card__fig {
  width: 120px; height: 120px; margin: 0 auto 2rem; display: block;
}
.insp-card__name {
  font-family: var(--display); font-size: .68rem;
  letter-spacing: .2em; text-transform: uppercase; color: var(--ink);
  margin-bottom: .35rem;
}
.insp-card__role {
  font-family: var(--fell); font-style: italic;
  font-size: .88rem; color: var(--gold-d); margin-bottom: 1.2rem;
}
.insp-card__desc {
  font-family: var(--serif); font-size: .88rem;
  color: var(--carbon); line-height: 1.8; margin-bottom: 1.2rem;
}
.insp-card__quote {
  border-left: 2px solid rgba(140,122,82,.5);
  padding: .8rem 1rem; text-align: left;
}
.insp-card__quote p {
  font-family: var(--fell); font-style: italic;
  font-size: .84rem; color: var(--gold-d); line-height: 1.6;
}
.insp-card__hint {
  font-family: var(--display); font-size: .42rem;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--gold-d); opacity: .7; margin-top: 1rem;
  display: block;
}

/* ═══════════════════════════════════════════════════════════════════════
   DIAGNÓSTICO
   ═══════════════════════════════════════════════════════════════════════ */
.diagnostico {
  padding: 7rem 0; background: var(--white);
}
.diagnostico__header { text-align: center; margin-bottom: 4rem; }
.diagnostico__wrap {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 5rem; align-items: start;
}
.diagnostico__copy h3 {
  font-family: var(--display); font-size: 1rem;
  letter-spacing: .06em; text-transform: uppercase; color: var(--ink);
  margin-bottom: 1rem;
}
.diagnostico__copy p {
  font-family: var(--serif); font-size: .95rem;
  color: var(--silver); line-height: 1.88; margin-bottom: 1.25rem;
}
.diagnostico__benefits { margin: 2rem 0; }
.diagnostico__benefit {
  display: flex; align-items: flex-start; gap: .8rem;
  padding: .7rem 0; border-bottom: 1px solid rgba(184,168,122,.1);
}
.diagnostico__benefit:last-child { border-bottom: none; }
.diagnostico__benefit-check {
  width: 18px; height: 18px; flex-shrink: 0;
  border: 1px solid var(--gold); display: flex;
  align-items: center; justify-content: center; margin-top: .1rem;
}
.diagnostico__benefit-check svg { width: 10px; height: 8px; stroke: var(--gold-d); }
.diagnostico__benefit-text {
  font-family: var(--serif); font-size: .9rem;
  color: var(--silver); line-height: 1.6;
}
.diagnostico__discount {
  background: var(--ink); padding: 1.5rem;
  margin-top: 1.5rem;
}
.diagnostico__discount p {
  font-family: var(--fell); font-style: italic;
  font-size: 1rem; color: var(--parchment); line-height: 1.65; margin: 0;
}
.diagnostico__discount strong { font-style: normal; color: var(--gold); }

/* Diagnostico CTA area (replaces iframe) */
.diagnostico__cta-wrap {
  border: 1px solid rgba(184,168,122,.15);
  padding: 3.5rem 2.5rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  background: var(--parchment);
  position: relative;
  min-height: 380px;
}
.diagnostico__cta-wrap::before {
  content: ''; position: absolute; inset: -6px;
  border: 1px solid rgba(184,168,122,.07);
}
.diagnostico__cta-icon {
  width: 64px; height: 64px; margin-bottom: 1.5rem;
  opacity: .55;
}
.diagnostico__cta-title {
  font-family: var(--display); font-size: .78rem;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--ink); margin-bottom: .8rem;
}
.diagnostico__cta-desc {
  font-family: var(--serif); font-size: .92rem;
  color: var(--silver); line-height: 1.8; margin-bottom: 2rem;
  max-width: 320px;
}
.btn-diagnostico {
  display: inline-flex; align-items: center; gap: .6rem;
  font-family: var(--display); font-size: .56rem;
  letter-spacing: .2em; text-transform: uppercase;
  padding: 1rem 2.2rem;
  background: var(--ink); color: var(--parchment);
  border: 1px solid var(--ink);
  transition: background .25s, border-color .25s, transform .2s;
}
.btn-diagnostico:hover { background: var(--gold-d); border-color: var(--gold-d); transform: translateY(-2px); }

/* ═══════════════════════════════════════════════════════════════════════
   RESOURCES
   ═══════════════════════════════════════════════════════════════════════ */
.resources {
  padding: 7rem 0; background: var(--parchment);
}
.resources__header { text-align: center; margin-bottom: 4rem; }
.resources__grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem; margin-bottom: 3.5rem;
}
.resource-card {
  background: var(--white); padding: 2.25rem 2rem;
  border: 1px solid rgba(184,168,122,.1);
  position: relative; overflow: hidden;
  transition: transform .3s, box-shadow .3s;
}
.resource-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 2px; background: var(--gold);
}
.resource-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,.07);
}
.resource-card__badge {
  display: inline-block; font-family: var(--display);
  font-size: .46rem; letter-spacing: .2em; text-transform: uppercase;
  padding: .28rem .8rem; background: rgba(184,168,122,.1);
  color: var(--gold-d); margin-bottom: 1.2rem;
}
.resource-card__title {
  font-family: var(--serif); font-size: 1rem;
  font-weight: 600; color: var(--ink); line-height: 1.4; margin-bottom: .7rem;
}
.resource-card__desc {
  font-family: var(--serif); font-size: .88rem;
  color: var(--silver); line-height: 1.75; margin-bottom: 1.5rem;
}
.resource-card__link {
  font-family: var(--display); font-size: .52rem;
  letter-spacing: .2em; text-transform: uppercase; color: var(--gold-d);
  display: inline-flex; align-items: center; gap: .5rem;
  transition: gap .25s;
}
.resource-card__link:hover { gap: .75rem; }

/* Newsletter */
.resources__newsletter {
  background: var(--ink); padding: 3rem;
  display: grid; grid-template-columns: 1fr auto;
  gap: 3rem; align-items: center;
}
.resources__newsletter-text .section-title--light {
  font-size: clamp(1.05rem, 1.7vw, 1.45rem); margin-bottom: .6rem;
}
.resources__newsletter-text p {
  font-family: var(--fell); font-style: italic;
  font-size: .95rem; color: rgba(245,240,232,.52);
}
.newsletter-form { display: flex; }
.newsletter-form input {
  font-family: var(--display); font-size: .58rem; letter-spacing: .1em;
  padding: .9rem 1.5rem;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(184,168,122,.22); border-right: none;
  color: var(--parchment); width: 260px; outline: none;
  transition: border-color .25s;
}
.newsletter-form input::placeholder { color: rgba(245,240,232,.3); }
.newsletter-form input:focus { border-color: var(--gold); }
.newsletter-form button {
  font-family: var(--display); font-size: .58rem;
  letter-spacing: .18em; text-transform: uppercase;
  padding: .9rem 1.5rem; background: var(--gold-d); color: var(--white);
  border: 1px solid var(--gold-d); cursor: pointer;
  transition: background .25s;
}
.newsletter-form button:hover { background: var(--gold); }

/* ═══════════════════════════════════════════════════════════════════════
   CONTACTO — New section
   ═══════════════════════════════════════════════════════════════════════ */
.contacto {
  padding: 8rem 0; background: var(--ink);
  position: relative; overflow: hidden;
}
.contacto__grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(184,168,122,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(184,168,122,.03) 1px, transparent 1px);
  background-size: 48px 48px;
}
/* Subtle warm glow top-center */
.contacto__grid-bg::after {
  content: '';
  position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
  width: 600px; height: 400px;
  background: radial-gradient(ellipse, rgba(184,168,122,.06) 0%, transparent 70%);
  pointer-events: none;
}
.contacto__inner { position: relative; z-index: 2; }

/* ── Header ── */
.contacto__header { text-align: center; margin-bottom: 4rem; }
.contacto__header h2 {
  font-family: var(--display);
  font-size: clamp(1.4rem, 2.5vw, 2.2rem);
  font-weight: 600; letter-spacing: .07em; text-transform: uppercase;
  color: var(--parchment); line-height: 1.2; margin-bottom: .6rem;
}
.contacto__header p {
  font-family: var(--fell); font-style: italic;
  font-size: 1.05rem; color: rgba(245,240,232,.45);
}

/* ── Main 2-col layout: form | aside ── */
.contacto__layout {
  display: grid; grid-template-columns: 1fr 320px;
  gap: 3rem; align-items: start;
}

/* ── Form panel ── */
.contacto__form-wrap {
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(184,168,122,.14);
  padding: 2.8rem 3rem;
  position: relative;
}
/* corner accents */
.contacto__form-wrap::before,
.contacto__form-wrap::after {
  content: ''; position: absolute;
  width: 18px; height: 18px;
  border-color: rgba(184,168,122,.3); border-style: solid;
}
.contacto__form-wrap::before { top: -1px; left: -1px; border-width: 1px 0 0 1px; }
.contacto__form-wrap::after  { bottom: -1px; right: -1px; border-width: 0 1px 1px 0; }

/* ── Section divider inside form ── */
.contact-form__section-label {
  font-family: var(--display); font-size: .46rem;
  letter-spacing: .34em; text-transform: uppercase;
  color: var(--gold-d); opacity: .7;
  display: flex; align-items: center; gap: .8rem;
  margin-bottom: 1.4rem; margin-top: .5rem;
}
.contact-form__section-label::after {
  content: ''; flex: 1; height: 1px;
  background: rgba(184,168,122,.12);
}

.contact-form { }
.contact-form__row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  margin-bottom: 0;
}
.contact-form__field { margin-bottom: 1.1rem; }
.contact-form label {
  font-family: var(--display); font-size: .44rem;
  letter-spacing: .22em; text-transform: uppercase;
  color: rgba(184,168,122,.65); display: block; margin-bottom: .45rem;
  transition: color .2s;
}
.contact-form__field:focus-within label { color: var(--gold); }
.contact-form input,
.contact-form select {
  width: 100%;
  font-family: var(--serif); font-size: .92rem;
  padding: .75rem 1rem;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(184,168,122,.18);
  border-bottom: 1px solid rgba(184,168,122,.32);
  color: var(--parchment); outline: none;
  transition: border-color .25s, background .2s, box-shadow .2s;
  -webkit-appearance: none;
}
.contact-form input::placeholder { color: rgba(245,240,232,.2); }
.contact-form input:focus,
.contact-form select:focus {
  border-color: var(--gold);
  background: rgba(184,168,122,.05);
  box-shadow: 0 4px 16px rgba(184,168,122,.06);
}
.contact-form select option { background: var(--carbon); color: var(--parchment); }

/* ── Radio tiles ── */
.contact-form__radio-group {
  display: grid; grid-template-columns: 1fr 1fr; gap: .55rem;
  margin-bottom: 2rem;
}
.contact-form__radio {
  position: relative; cursor: pointer;
  padding: .9rem 1rem .9rem 2.8rem;
  border: 1px solid rgba(184,168,122,.16);
  background: rgba(255,255,255,.02);
  transition: border-color .2s, background .2s;
}
.contact-form__radio:hover {
  border-color: rgba(184,168,122,.38);
  background: rgba(184,168,122,.04);
}
/* hide native radio */
.contact-form__radio input[type="radio"] {
  position: absolute; opacity: 0; width: 0; height: 0;
}
/* custom circle indicator */
.contact-form__radio::before {
  content: '';
  position: absolute; left: .9rem; top: 50%; transform: translateY(-50%);
  width: 14px; height: 14px; border-radius: 50%;
  border: 1px solid rgba(184,168,122,.35);
  background: transparent;
  transition: border-color .2s, background .2s;
}
/* selected state */
.contact-form__radio:has(input:checked) {
  border-color: var(--gold);
  background: rgba(184,168,122,.07);
}
.contact-form__radio:has(input:checked)::before {
  background: var(--gold-d);
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(184,168,122,.12);
}
.contact-form__radio:has(input:checked) span { color: var(--parchment); }
.contact-form__radio span {
  font-family: var(--serif); font-size: .88rem;
  color: rgba(245,240,232,.45);
  transition: color .2s;
  display: block; line-height: 1.35;
}

/* ── Submit button ── */
.contact-form__submit {
  display: flex; align-items: center; justify-content: space-between;
  font-family: var(--display); font-size: .52rem;
  letter-spacing: .22em; text-transform: uppercase;
  padding: 1.1rem 1.8rem;
  background: var(--gold-d); color: var(--white);
  border: 1px solid var(--gold-d); cursor: pointer; width: 100%;
  transition: background .25s, border-color .25s, transform .2s, box-shadow .2s;
  position: relative; overflow: hidden;
}
.contact-form__submit::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.06), transparent);
  transform: translateX(-100%);
  transition: transform .5s var(--ease-out);
}
.contact-form__submit:hover {
  background: var(--gold); border-color: var(--gold);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(184,168,122,.22);
}
.contact-form__submit:hover::before { transform: translateX(100%); }
.contact-form__submit-text { }
.contact-form__submit-icon {
  width: 36px; height: 36px;
  border: 1px solid rgba(255,255,255,.25); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: border-color .2s, transform .2s;
}
.contact-form__submit:hover .contact-form__submit-icon {
  border-color: rgba(255,255,255,.6); transform: translateX(3px);
}

/* ── Success state ── */
.contact-success {
  display: none;
  padding: 3.5rem 2.5rem;
  background: rgba(184,168,122,.06);
  border: 1px solid rgba(184,168,122,.2);
  text-align: center;
  position: relative;
}
.contact-success::before {
  content: ''; position: absolute; inset: -6px;
  border: 1px solid rgba(184,168,122,.07);
  pointer-events: none;
}
.contact-success__icon {
  width: 56px; height: 56px; margin: 0 auto 1.8rem;
  border: 1px solid var(--gold); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.contact-success__icon svg { width: 22px; height: 18px; stroke: var(--gold); }
.contact-success h3 {
  font-family: var(--display); font-size: .74rem;
  letter-spacing: .14em; text-transform: uppercase;
  color: var(--parchment); margin-bottom: 1rem;
}
.contact-success p {
  font-family: var(--fell); font-style: italic;
  font-size: 1rem; color: rgba(245,240,232,.62); line-height: 1.85;
}

/* ── Aside column ── */
.contacto__aside { display: flex; flex-direction: column; gap: 0; }
.contacto__wa-box {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(184,168,122,.2);
  padding: 2.2rem 2rem 2rem;
  margin-bottom: 0;
  position: relative;
}
.contacto__wa-box::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  opacity: .5;
}
.contacto__wa-title {
  font-family: var(--display); font-size: .54rem;
  letter-spacing: .28em; text-transform: uppercase;
  color: var(--gold); margin-bottom: .65rem; display: block;
}
.contacto__wa-desc {
  font-family: var(--fell); font-style: italic;
  font-size: .88rem; color: rgba(245,240,232,.45);
  line-height: 1.65; margin-bottom: 1.4rem;
}
.contacto__wa-btn {
  display: flex; align-items: center; justify-content: center; gap: .7rem;
  font-family: var(--display); font-size: .48rem;
  letter-spacing: .2em; text-transform: uppercase;
  padding: .85rem 1.4rem;
  background: #25D366; color: var(--white);
  border: none; cursor: pointer; text-decoration: none; width: 100%;
  transition: background .25s, transform .2s;
}
.contacto__wa-btn:hover { background: #1da851; transform: translateY(-2px); }
.contacto__wa-icon { width: 18px; height: 18px; flex-shrink: 0; }

/* contact info list below WA box */
.contacto__info-list {
  border: 1px solid rgba(184,168,122,.14);
  border-top: none;
  padding: .4rem 0;
}
.contacto__info-item {
  padding: .85rem 2rem;
  border-bottom: 1px solid rgba(184,168,122,.08);
  display: flex; gap: .9rem; align-items: center;
}
.contacto__info-item:last-child { border-bottom: none; }
.contacto__info-label {
  font-family: var(--display); font-size: .42rem;
  letter-spacing: .22em; text-transform: uppercase;
  color: var(--gold-d); min-width: 72px; opacity: .8;
}
.contacto__info-val {
  font-family: var(--serif); font-size: .86rem;
  color: rgba(245,240,232,.48); line-height: 1.4;
}

/* ═══════════════════════════════════════════════════════════════════════
   FINAL CTA
   ═══════════════════════════════════════════════════════════════════════ */
.cta-final {
  padding: 9rem 0; background: var(--parchment);
  position: relative; overflow: hidden; text-align: center;
}
.cta-final__grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(140,122,82,.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(140,122,82,.05) 1px, transparent 1px);
  background-size: 48px 48px;
}
.cta-final__inner { position: relative; z-index: 2; }
.cta-final__eyebrow {
  display: flex; align-items: center; justify-content: center;
  gap: 1rem; margin-bottom: 2rem;
}
.cta-final__eyebrow::before,
.cta-final__eyebrow::after {
  content: ''; display: block; width: 28px; height: 1px;
  background: var(--gold-d); opacity: .6;
}
.cta-final__headline {
  font-family: var(--display);
  font-size: clamp(1.8rem, 4.2vw, 3.2rem);
  font-weight: 600; letter-spacing: .07em; text-transform: uppercase;
  color: var(--ink); line-height: 1.1; margin-bottom: 1.5rem;
}
.cta-final__sub {
  font-family: var(--fell); font-style: italic;
  font-size: clamp(.95rem, 1.5vw, 1.15rem);
  color: var(--silver); margin-bottom: 3rem;
  max-width: 500px; margin-left: auto; margin-right: auto;
}
.cta-final__btns {
  display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
  margin-bottom: 4rem;
}
.btn-light {
  display: inline-flex; align-items: center; gap: .6rem;
  font-family: var(--display); font-size: .56rem;
  letter-spacing: .2em; text-transform: uppercase;
  padding: .95rem 2.2rem;
  background: var(--ink); color: var(--parchment);
  border: 1px solid var(--ink);
  transition: background .25s, border-color .25s, transform .2s;
}
.btn-light:hover { background: var(--gold-d); color: var(--white); border-color: var(--gold-d); transform: translateY(-2px); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: .6rem;
  font-family: var(--display); font-size: .56rem;
  letter-spacing: .2em; text-transform: uppercase;
  padding: .95rem 2.2rem;
  background: transparent; color: var(--silver);
  border: 1px solid rgba(26,26,24,.2);
  transition: border-color .25s, color .25s, transform .2s;
}
.btn-ghost:hover { border-color: var(--gold-d); color: var(--gold-d); transform: translateY(-2px); }
.cta-final__contacts {
  display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap;
}
.cta-contact { text-align: center; }
.cta-contact__label {
  font-family: var(--display); font-size: .5rem;
  letter-spacing: .3em; text-transform: uppercase;
  color: var(--gold-d); display: block; margin-bottom: .4rem;
}
.cta-contact__value {
  font-family: var(--serif); font-size: .92rem;
  color: var(--silver); transition: color .25s;
}
.cta-contact a:hover .cta-contact__value { color: var(--gold-d); }

/* ═══════════════════════════════════════════════════════════════════════
   FOOTER
   ═══════════════════════════════════════════════════════════════════════ */
footer {
  background: var(--carbon); padding: 4rem 0 2rem;
}
.footer__inner {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem; margin-bottom: 3rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid rgba(184,168,122,.1);
}
.footer__brand-desc {
  font-family: var(--serif); font-size: .9rem;
  color: rgba(245,240,232,.42); line-height: 1.8; margin-top: 1rem;
  max-width: 280px;
}
.footer__col-title {
  font-family: var(--display); font-size: .54rem;
  letter-spacing: .32em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 1.25rem; display: block;
}
.footer__links { display: flex; flex-direction: column; gap: .6rem; }
.footer__links a {
  font-family: var(--serif); font-size: .9rem;
  color: rgba(245,240,232,.42); transition: color .25s;
}
.footer__links a:hover { color: var(--parchment); }
.footer__bottom {
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 1rem;
}
.footer__copy,
.footer__ruc {
  font-family: var(--display); font-size: .5rem;
  letter-spacing: .14em; text-transform: uppercase;
  color: rgba(245,240,232,.22);
}
.footer__social {
  display: flex; gap: 1.2rem; align-items: center;
}
.footer__social a {
  font-family: var(--display); font-size: .52rem;
  letter-spacing: .14em; text-transform: uppercase;
  color: rgba(245,240,232,.35); transition: color .25s;
}
.footer__social a:hover { color: var(--gold); }

/* ═══════════════════════════════════════════════════════════════════════
   RESPONSIVE — TABLET
   ═══════════════════════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .hero { grid-template-columns: 1fr; }
  .hero__left { padding: 6rem 2.5rem 4rem; order: 2; }
  .hero__right { min-height: 400px; order: 1; }
  .disruption__inner { grid-template-columns: 1fr; gap: 3rem; }
  .ecosystem__grid { grid-template-columns: 1fr 1fr; }
  .services__header { grid-template-columns: 1fr; gap: 1.5rem; }
  .services__grid { grid-template-columns: 1fr 1fr; }
  .process__steps { grid-template-columns: 1fr 1fr; }
  .process__connector { display: none; }
  .about__inner { grid-template-columns: 1fr; gap: 3rem; }
  .about__visual { order: -1; max-width: 480px; margin: 0 auto; }
  .diagnostico__wrap { grid-template-columns: 1fr; }
  .contacto__layout { grid-template-columns: 1fr; gap: 2rem; }
  .contacto__form-wrap { padding: 2rem 1.8rem; }
  .resources__newsletter { grid-template-columns: 1fr; gap: 2rem; }
  .footer__inner { grid-template-columns: 1fr 1fr; }
}

/* ═══════════════════════════════════════════════════════════════════════
   RESPONSIVE — MOBILE
   ═══════════════════════════════════════════════════════════════════════ */
@media (max-width: 768px) {
  .container { padding: 0 1.5rem; }
  .hero__stats { flex-wrap: wrap; gap: 1.5rem; }
  .nav__links, .nav__cta { display: none; }
  .nav__burger { display: flex; }
  .ecosystem__grid,
  .inspiration__grid,
  .resources__grid { grid-template-columns: 1fr; }
  .services__grid { grid-template-columns: 1fr; }
  .process__steps { grid-template-columns: 1fr; }
  .cta-final__contacts { flex-direction: column; gap: 1.5rem; align-items: center; }
  .newsletter-form { flex-direction: column; }
  .newsletter-form input { width: 100%; border-right: 1px solid rgba(184,168,122,.22); border-bottom: none; }
  .footer__inner { grid-template-columns: 1fr; }
  .footer__bottom { flex-direction: column; text-align: center; }
  .hero__headline { font-size: 2.2rem; }
  .contact-form__row { grid-template-columns: 1fr; }
  .contact-form__radio-group { grid-template-columns: 1fr; }
  .modal-box__header { padding: 1.8rem 1.5rem 1.4rem; }
  .modal-box__body { padding: 1.8rem 1.5rem; }
  .modal-gallery__grid { grid-template-columns: 1fr 1fr; }
}

/* ═══════════════════════════════════════════════════════════════════════
   BREATHING ANIMATION
   ═══════════════════════════════════════════════════════════════════════ */
@keyframes heroBreathe {
  0%, 100% { opacity: 1; }
  50%       { opacity: .72; }
}
.hero-done .hl,
.hero-done .hk {
  animation: heroBreathe 4.2s ease-in-out infinite;
}
.hero-done #hl2 { animation-delay: .15s; }
.hero-done #hl3 { animation-delay: .3s; }
.hero-done #hl4 { animation-delay: .45s; }
.hero-done #hk1 { animation-delay: .05s; }
.hero-done #hk2 { animation-delay: .1s; }
.hero-done #hk3 { animation-delay: .2s; }
.hero-done #hk4 { animation-delay: .3s; }
.hero-done #hk5 { animation-delay: .4s; }

/* ─── SCROLL-BASED HORIZONTAL TICKER ─── */
.ticker-band {
  background: var(--ink); padding: .85rem 0; overflow: hidden;
  border-top: 1px solid rgba(184,168,122,.1);
  border-bottom: 1px solid rgba(184,168,122,.1);
}
.ticker-track {
  display: flex; gap: 0;
  animation: ticker 28s linear infinite;
  width: max-content;
}
.ticker-track:hover { animation-play-state: paused; }
.ticker-item {
  font-family: var(--display); font-size: .56rem;
  letter-spacing: .3em; text-transform: uppercase;
  color: rgba(245,240,232,.35); white-space: nowrap;
  padding: 0 2.5rem;
}
.ticker-item--gold { color: var(--gold); }
.ticker-sep {
  color: rgba(184,168,122,.3); padding: 0 .8rem;
}
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* ─── Floating scroll indicator ─── */
.scroll-indicator {
  position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: .5rem;
  opacity: .45; animation: float 2.5s ease-in-out infinite;
}
.scroll-indicator span {
  font-family: var(--display); font-size: .46rem;
  letter-spacing: .3em; text-transform: uppercase; color: var(--silver);
}
.scroll-indicator__arrow {
  width: 1px; height: 32px; background: var(--silver);
  animation: scrollArrow 2.5s ease-in-out infinite;
}
@keyframes float { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }
@keyframes scrollArrow { 0%{transform:scaleY(0);transform-origin:top} 50%{transform:scaleY(1);transform-origin:top} 51%{transform:scaleY(1);transform-origin:bottom} 100%{transform:scaleY(0);transform-origin:bottom} }

@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
</style>
